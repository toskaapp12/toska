# Xcode
build/
DerivedData/
*.xcuserstate
xcuserdata/
*.xcuserdatad/
*.moved-aside

# Swift Package Manager
.swiftpm/
Package.resolved

# CocoaPods (if used later)
Pods/

# Node (Cloud Functions, rules tests)
node_modules/
functions/node_modules/
firestore-tests/node_modules/
# firestore-tests/package-lock.json is committed so CI caches npm installs
# reproducibly. Functions has no lockfile because the deploy pipeline
# resolves dependencies fresh on the cloud builder.

# Firebase CLI debug output (regenerated on every deploy, can be large)
firebase-debug.log
firebase-debug.*.log
.firebase/

# Firebase emulator debug logs (firestore, auth, ui, etc.)
*-debug.log

# Claude Code session data
.claude/

# macOS
.DS_Store

# Local environment
*.local
.env

# Firebase config (client key — safe but triggers GitHub secret scanning)
**/GoogleService-Info.plist
