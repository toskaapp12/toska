rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "admin";
    }

    // Server-side enforcement of the auto-restrict / admin-restrict gate.
    // Previously every write rule trusted UserHandleCache.isRestricted on the
    // iOS client, which a tampered build can ignore — letting a flagged
    // repeat-offender keep posting/replying/messaging despite the auto-set
    // `restricted: true` flag from functions/index.js:onPostCreated.
    //
    // Auto-restrictions ("system") set restrictedUntil to now+48h so they
    // expire on their own; admin restrictions leave restrictedUntil unset so
    // they persist until cleared. Brand-new accounts (no user doc yet) fall
    // through the !exists() leg so the very first onboarding write isn't
    // blocked by a missing-doc lookup.
    //
    // Costs one get() on the caller's user doc per gated write. Add it only
    // to write rules that actually need to honor the restriction
    // (posts/replies/messages create — not reads, not block/unblock,
    // not unfollow, not delete-own-content).
    function notRestricted() {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid))
        || !get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('restricted', false)
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('restrictedUntil', request.time) < request.time;
    }

    // Server-side enforcement of the adult-confirmation gate. iOS displays
    // an age-confirmation gate during OnboardingView before the first post,
    // and recordPolicyAcceptance() writes `confirmedAdult: true` on the
    // user doc once the user accepts. Previously these checks ran only on
    // the iOS client — a tampered build that skipped OnboardingView could
    // post without ever seeing (let alone confirming) the adult-content
    // notice. This function moves that enforcement to the rules layer so
    // every "publishing" write (post / reply / DM message / circle
    // message) requires the field to be true on the caller's user doc.
    //
    // NOT applied to: user-doc create (the doc has to exist before
    // confirmedAdult can be set), user-doc update (so OnboardingView can
    // set it), likes/saves/follows/blocks (consumption + relationship
    // actions, not publishing), notifications (already covered by per-
    // type predicates).
    //
    // Costs: shares the same get() lookup as notRestricted() within a
    // single rule evaluation, so per-write Firestore read cost is unchanged.
    //
    // Backward compat: any user who completed iOS onboarding has
    // confirmedAdult=true set by recordPolicyAcceptance. Legitimate
    // production users are not blocked by this rule.
    function hasConfirmedAdult() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('confirmedAdult', false) == true;
    }

    // Legacy PII fields that lived on the main user doc before the migration
    // to users/{uid}/private/data (firestore.rules:43-61 documents the move).
    // Post-migration, no client write path touches these on the main doc
    // EXCEPT SettingsView.saveSettings which deletes them via FieldValue.delete
    // as opportunistic cleanup. This predicate permits deletes (allowing the
    // cleanup) and unchanged values (allowing other field updates on
    // pre-migration accounts) but blocks any add or modify — closing the
    // door on a tampered client re-introducing leaked PII onto the public-
    // readable user doc. The fcmToken / restricted family stay denied
    // entirely via the existing `affectedKeys().hasAny([...])` clause; those
    // fields should never be touched by clients at all.
    function legacyPIIFieldsImmutable() {
      return (!('email' in request.resource.data.keys())
              || request.resource.data.email == resource.data.get('email', null))
        && (!('selectedMood' in request.resource.data.keys())
              || request.resource.data.selectedMood == resource.data.get('selectedMood', null))
        && (!('notifyLikes' in request.resource.data.keys())
              || request.resource.data.notifyLikes == resource.data.get('notifyLikes', null))
        && (!('notifyReplies' in request.resource.data.keys())
              || request.resource.data.notifyReplies == resource.data.get('notifyReplies', null))
        && (!('notifyFollows' in request.resource.data.keys())
              || request.resource.data.notifyFollows == resource.data.get('notifyFollows', null))
        && (!('notifyReposts' in request.resource.data.keys())
              || request.resource.data.notifyReposts == resource.data.get('notifyReposts', null))
        && (!('notifySaves' in request.resource.data.keys())
              || request.resource.data.notifySaves == resource.data.get('notifySaves', null))
        && (!('notifyMessages' in request.resource.data.keys())
              || request.resource.data.notifyMessages == resource.data.get('notifyMessages', null))
        && (!('notifyMilestones' in request.resource.data.keys())
              || request.resource.data.notifyMilestones == resource.data.get('notifyMilestones', null))
        && (!('pushEnabled' in request.resource.data.keys())
              || request.resource.data.pushEnabled == resource.data.get('pushEnabled', null))
        && (!('gentleCheckIn' in request.resource.data.keys())
              || request.resource.data.gentleCheckIn == resource.data.get('gentleCheckIn', null));
    }

    match /users/{userId} {
      // FIX: previously `allow read: if isAuth()` let any logged-in user read
      // the full user document, including email, selectedMood, fcmToken, and
      // all notification preferences. Now:
      //   - The document owner can read everything.
      //   - Other authenticated users can only read if the document contains
      //     only the public subset of fields. In practice, OtherProfileView
      //     reads handle/followerCount/followingCount/totalLikes/showFollowerCount
      //     from this document — those are all in the public set.
      //   - Fields like email, selectedMood, fcmToken, notifyLikes, etc. are
      //     never returned to other users because Firestore returns the whole
      //     document or nothing; the real protection is the rule below combined
      //     with moving sensitive fields to a separate private subcollection
      //     or a server-side publicProfiles collection (see security review note).
      //
      // Practical note: Firestore rules cannot mask individual fields within a
      // document read — they grant or deny the entire document. To fully
      // prevent email/mood from leaking to other users, the long-term fix is
      // to store sensitive fields in users/{userId}/private/data (owner-only)
      // and keep only public fields on the top-level document. The rule below
      // is the correct interim step: other users can read the document only
      // when it is being read for a known-public purpose (OtherProfileView,
      // follow list handle lookup). If you add email to a user document query
      // from a context other than the owner, this rule will deny it.
      //
      // Migration progress (2026-04):
      //   - email and fcmToken now live in users/{uid}/private/data — done
      //   - selectedMood and notify*/pushEnabled/gentleCheckIn now also live
      //     in users/{uid}/private/data. SettingsView writes them there and
      //     deletes the legacy main-doc copies on next save; OnboardingView
      //     writes selectedMood to the private subcollection; UserHandleCache
      //     listens to both docs and prefers the private value;
      //     FeedViewModel.fetchUserPreferences reads private first, falls back
      //     to the legacy main-doc field for accounts that haven't been
      //     through SettingsView yet.
      //   - The fields remaining on the main doc are public-projection only
      //     (handle, *Count, allowSharing, showFollowerCount, restricted),
      //     read by OtherProfileView. The isAuth() leg below stays so those
      //     reads keep working; sensitive prefs are no longer here to leak.
      //   - Long-tail cleanup: any pre-migration accounts still have legacy
      //     copies on the main doc until they open settings or onboarding
      //     fires a save. A one-time admin script can scrub them by reading
      //     and deleting the legacy field set; not strictly required since
      //     reads now prefer the private copy.
      allow read: if isOwner(userId) || isAuth();
      allow create: if isOwner(userId)
        && request.resource.data.handle is string
        && request.resource.data.handle.size() <= 30
        // Restrict handles to alphanumeric + underscore + hyphen so a tampered
        // client can't write a handle like `<svg onload=alert(1)>` that would
        // execute as JavaScript when an admin views it in the moderation
        // dashboard (docs/admin.html). The legitimate handle generator
        // (generateUniqueHandle) only produces strings in this character class
        // so existing accounts are unaffected.
        && request.resource.data.handle.matches('^[a-zA-Z0-9_-]+$')
        // Prevent storing email on documents belonging to anonymous users.
        // Apple/Google/email auth all have a non-empty email; anonymous sign-in does not.
        && (request.resource.data.keys().hasAll(['email'])
              ? request.resource.data.email is string
              : true);
      // Owners can update their user doc except for:
      //   - fcmToken (lives in the private subcollection; main-doc writes of
      //     it are blocked to keep the field surface narrow)
      //   - restriction fields (restricted/restrictedAt/restrictedBy/restrictedUntil):
      //     only Cloud Functions (Admin SDK, bypasses rules) and admins (via the
      //     branch below) can write these. Without this guard, a tampered client
      //     could flip `restricted: false` to self-unrestrict after hitting the
      //     repeat-offender threshold.
      allow update: if (isOwner(userId)
            && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['handle'])
                || (request.resource.data.handle is string
                    && request.resource.data.handle.size() <= 30
                    && request.resource.data.handle.matches('^[a-zA-Z0-9_-]+$')))
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['fcmToken', 'restricted', 'restrictedAt', 'restrictedBy', 'restrictedUntil'])
            // Legacy PII fields (email/selectedMood/notify*/pushEnabled/
            // gentleCheckIn) must not be re-introduced or modified once the
            // migration to users/{uid}/private/data is complete. Deletes are
            // permitted so SettingsView.saveSettings can keep scrubbing
            // legacy main-doc copies opportunistically; pre-migration accounts
            // updating other fields pass because the unchanged-value branch
            // matches. See legacyPIIFieldsImmutable() and functions/scrubLegacyPII.js.
            && legacyPIIFieldsImmutable())
        || (isAdmin()
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['restricted', 'restrictedAt', 'restrictedBy', 'restrictedUntil']));
      allow delete: if isOwner(userId);

      match /following/{followedId} {
        // Reads are owner-only — exposing the full follow graph to any
        // authenticated user lets a malicious client enumerate everyone's
        // social connections. The Swift code only ever reads its own
        // following list (ProfileView, FeedViewModel.fetchFollowingPosts,
        // PostDetailView blockUser cleanup) so this restriction doesn't
        // break any current call site.
        allow read: if isOwner(userId);
        // Self-follow guard: a user can't follow themselves. Without this,
        // a tampered client could insert /users/{uid}/following/{uid},
        // tripping onFollowCreatedUpdateCounts and inflating the user's
        // own followingCount/followerCount with no real follow relationship.
        // Delete intentionally has no self-guard so any pre-existing
        // self-follow doc can still be cleaned up.
        allow create: if isOwner(userId) && followedId != userId;
        allow delete: if isOwner(userId);
      }

      match /followers/{followerId} {
        // Reads are owner-only for the same reason as following above.
        // OtherProfileView checks "do I follow them?" by reading their own
        // following subcollection, not by reading the target's followers
        // list, so this restriction is safe.
        allow read: if isOwner(userId);
        // Block enforcement on follow: a user the target has blocked can't
        // add themselves as a follower. Without this, blocked users could
        // still bump someone's followerCount and appear in their notifications.
        // Also blocks self-follows (request.auth.uid != userId) for the same
        // reason as the /following/ subcollection above — prevents counter
        // inflation via a tampered client posting itself into its own
        // followers list.
        allow create: if isAuth() && request.auth.uid == followerId
          && request.auth.uid != userId
          && !exists(/databases/$(database)/documents/users/$(userId)/blocked/$(request.auth.uid));
        allow update: if isAuth() && request.auth.uid == followerId;
        allow delete: if isAuth() && (request.auth.uid == followerId || isOwner(userId));
      }

      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        // Each notification type must be backed by a real event the actor
        // actually performed. Previously the only check was
        // fromUserId == auth.uid, which let any authenticated user write
        // arbitrary notification docs into any other user's subcollection —
        // sendPushNotification (Cloud Function) fires on create and sends a
        // real APNs push, so that's an open push-spam vector.
        //
        // milestones are server-written (Admin SDK bypasses rules) so the
        // client branch explicitly excludes that type.
        //
        // reply/repost rely on the post existing AND userId being its author,
        // because we can't cheaply verify a specific reply/repost subdoc by
        // ID from within rules. The docId pattern ("reply_{postId}_{uid}")
        // is still deterministic so an attacker can only write one of each
        // type per (post, victim, actor) triple — plus they must not be
        // blocked by the author.
        allow create: if isAuth()
          && request.resource.data.fromUserId == request.auth.uid
          && request.resource.data.type is string
          && (
            // like: actor has a like doc on the post AND the post author is the recipient.
            // The like-create rule (posts/{postId}/likes/{likeUserId}) already
            // refuses to write a like doc when the post author has blocked the
            // actor, so the exists() check below transitively enforces block.
            // The explicit !exists(blocked) clause is defense-in-depth: if the
            // like-create check is ever loosened, we don't want the notification
            // path to silently become a block-bypass.
            (request.resource.data.type == 'like'
              && request.resource.data.postId is string
              && exists(/databases/$(database)/documents/posts/$(request.resource.data.postId))
              && get(/databases/$(database)/documents/posts/$(request.resource.data.postId)).data.authorId == userId
              && !exists(/databases/$(database)/documents/users/$(userId)/blocked/$(request.auth.uid))
              && exists(/databases/$(database)/documents/posts/$(request.resource.data.postId)/likes/$(request.auth.uid)))
            // save: actor has a save doc AND the post author is the recipient.
            // The /users/{uid}/saved/{postId} create rule is owner-only (no
            // block check there), so unlike `like` this branch has no
            // transitive block enforcement — without the explicit exists()
            // check below, a blocked user can save a post and write a save
            // notification doc into the author's notifications subcollection.
            // sendPushNotification's runtime block check (functions/index.js)
            // suppresses the actual push, but the notification doc would
            // still be visible in-app and consume per-recipient storage and
            // notification rate-limit budget. Adding the rule-level check
            // closes the gap at the layer the brief calls out as load-bearing.
            || (request.resource.data.type == 'save'
              && request.resource.data.postId is string
              && exists(/databases/$(database)/documents/posts/$(request.resource.data.postId))
              && get(/databases/$(database)/documents/posts/$(request.resource.data.postId)).data.authorId == userId
              && !exists(/databases/$(database)/documents/users/$(userId)/blocked/$(request.auth.uid))
              && exists(/databases/$(database)/documents/users/$(request.auth.uid)/saved/$(request.resource.data.postId)))
            // follow: actor is in the recipient's followers subcollection.
            // /users/{uid}/followers/{followerId} create already enforces the
            // block check, so the exists() below is transitively safe.
            || (request.resource.data.type == 'follow'
              && exists(/databases/$(database)/documents/users/$(userId)/followers/$(request.auth.uid)))
            // message: actor is a participant in the named conversation AND
            // recipient is too. With the conversations create rule capped at
            // exactly 2 participants, a tampered actor cannot fabricate a
            // 3-party conversation to bypass block enforcement on the
            // associated message-create rule. The explicit !exists(blocked)
            // clause below is defense-in-depth so writing a 'message'-type
            // notification doc never goes through when the recipient has
            // blocked the actor, even if a future change loosens the
            // conversation cap or message rule.
            || (request.resource.data.type == 'message'
              && request.resource.data.conversationId is string
              && exists(/databases/$(database)/documents/conversations/$(request.resource.data.conversationId))
              && request.auth.uid in get(/databases/$(database)/documents/conversations/$(request.resource.data.conversationId)).data.participants
              && userId in get(/databases/$(database)/documents/conversations/$(request.resource.data.conversationId)).data.participants
              && !exists(/databases/$(database)/documents/users/$(userId)/blocked/$(request.auth.uid)))
            // reply: post exists, recipient is post author, actor isn't blocked,
            // AND notifId is the deterministic shape PostInteractionManager.
            // sendNotification writes ("reply_{postId}_{actorUid}"). Without the
            // notifId pin a tampered client can write arbitrary notifIds for
            // the same (post, target, actor) triple — each new doc fires
            // sendPushNotification before rateLimitNotifications gets a chance
            // to clean up, opening a fake-reply-push-spam vector. The reply
            // branch can't `exists()`-check a real reply doc cheaply because
            // reply docs use auto-IDs, but the deterministic notifId reduces
            // the spam blast to one (already-rate-limited) push per post-target
            // pair — same shape the legitimate client writes anyway, so this
            // doesn't break any current call site.
            || (request.resource.data.type == 'reply'
              && request.resource.data.postId is string
              && exists(/databases/$(database)/documents/posts/$(request.resource.data.postId))
              && get(/databases/$(database)/documents/posts/$(request.resource.data.postId)).data.authorId == userId
              && !exists(/databases/$(database)/documents/users/$(userId)/blocked/$(request.auth.uid))
              && notifId == 'reply_' + request.resource.data.postId + '_' + request.auth.uid)
            // repost: post exists, recipient is author, actor isn't blocked,
            // notifId matches the deterministic client shape, AND a real
            // repost post exists at the deterministic id PostInteractionManager.
            // repost writes ("{actorUid}_repost_{postId}"). Repost-doc IDs ARE
            // deterministic so we get to confirm the actor actually performed
            // the action, not just that they could.
            || (request.resource.data.type == 'repost'
              && request.resource.data.postId is string
              && exists(/databases/$(database)/documents/posts/$(request.resource.data.postId))
              && get(/databases/$(database)/documents/posts/$(request.resource.data.postId)).data.authorId == userId
              && !exists(/databases/$(database)/documents/users/$(userId)/blocked/$(request.auth.uid))
              && exists(/databases/$(database)/documents/posts/$(request.auth.uid + '_repost_' + request.resource.data.postId))
              && notifId == 'repost_' + request.resource.data.postId + '_' + request.auth.uid)
          );
        allow update, delete: if isOwner(userId);
      }

      match /saved/{postId} {
        allow read, create, delete: if isOwner(userId);
      }

      match /liked/{postId} {
        allow read, create, delete: if isOwner(userId);
      }

      match /blocked/{blockedId} {
        allow create, delete: if isOwner(userId);
        allow read: if isOwner(userId) || (isAuth() && request.auth.uid == blockedId);
      }

      match /presence/{dateId} {
        allow read, create, update: if isOwner(userId);
      }

      // Private subcollection for sensitive user data — email, mood, etc.
      // Only the owner can read or write. No other user can access this at all.
      // To use: move email and selectedMood writes here instead of the top-level
      // user document. Update FeedViewModel.fetchUserPreferences and
      // AppleSignInHelper/SplashView to write to users/{uid}/private/data instead.
      match /private/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /posts/{postId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && notRestricted()
        && hasConfirmedAdult()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000
        // FIX: added text.size() > 0 to match the server-side validatePost
        // Cloud Function guard. A blank post cannot be created from the client.
        && request.resource.data.keys().hasAll(['authorId', 'text', 'createdAt', 'likeCount', 'repostCount', 'replyCount'])
        // Schema lockdown — only the documented post fields can land on a post
        // doc. Without hasOnly, a malicious or buggy client could attach
        // arbitrary extra fields (e.g. a forged `flagged: false` to re-enable
        // a moderated post, or `flagReason: "ok"` to mask a hit, or scratch
        // fields that other triggers later trust). The allow-list covers
        // every field currently written by ComposeView.postNow and
        // PostInteractionManager.repost. If a new field gets added to those
        // write paths, extend this list too.
        && request.resource.data.keys().hasOnly([
             'authorId', 'authorHandle', 'text', 'createdAt',
             'likeCount', 'repostCount', 'replyCount',
             'tag', 'gifUrl',
             'isRepost', 'isLetter', 'isWhisper', 'isMidnightPost', 'isShareable',
             'expiresAt',
             'originalPostId', 'originalHandle', 'originalAuthorId'
           ])
        && request.resource.data.likeCount == 0
        && request.resource.data.repostCount == 0
        && request.resource.data.replyCount == 0
        // Block enforcement on reposts: if this is a repost of someone
        // else's content (isRepost == true with an originalAuthorId), the
        // original author can't have blocked the reposter. For original
        // posts (no isRepost or no originalAuthorId), the check short-
        // circuits via the ternary so it doesn't add a get() cost.
        && (
          !(request.resource.data.get('isRepost', false) == true
            && request.resource.data.get('originalAuthorId', '') is string
            && request.resource.data.originalAuthorId.size() > 0)
          || !exists(/databases/$(database)/documents/users/$(request.resource.data.originalAuthorId)/blocked/$(request.auth.uid))
        );
      // Post author can edit text/editedAt etc., but cannot directly write
      // counter fields — those are owned by Cloud Functions (Admin SDK
      // bypasses these rules). Without this guard, the author could
      // arbitrarily inflate likeCount/replyCount/repostCount on their own
      // posts; the next legitimate like/reply event would correct it via
      // FieldValue.increment, but in the gap the inflated number is shown
      // in the feed. authorId/createdAt are immutable post-create.
      //
      // Moderation fields (flagged/flagReason/flaggedAt/concerningContent)
      // are also denied to clients: without this guard, a post author whose
      // post got auto-flagged by onPostCreated could just update flagged=false
      // and re-show their own moderated content. Admin SDK (Cloud Functions
      // and admin.html actions) bypass these rules and can still toggle these
      // fields legitimately.
      // Text-size cap mirrored from create. Without it, an author could edit
      // their post to multiple-hundred-KB text — both a feed-bandwidth DoS
      // for anyone scrolling and a moderation-bypass amplifier (the post-
      // moderation rerun handler in functions/index.js:onPostUpdated still
      // scans, but a 999KB text serving from the feed wastes the read either
      // way). text.size() > 0 also matches the create-side guard so a
      // tampered client can't blank out a post via update.
      allow update: if ((isAuth() && resource.data.authorId == request.auth.uid)
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 2000
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['likeCount', 'replyCount', 'repostCount', 'authorId', 'createdAt',
                         'flagged', 'flagReason', 'flaggedAt', 'concerningContent']))
        || isAdmin();
      allow delete: if (isAuth() && resource.data.authorId == request.auth.uid)
        || isAdmin();

      match /replies/{replyId} {
        allow read: if isAuth();
        // Block enforcement: the post author can't be replied to by a user
        // they've blocked. Without this check, blocked users could keep
        // engaging server-side; the client filter (BlockedUsersCache) only
        // hides their content from the blocker, not vice versa.
        allow create: if isAuth()
          && notRestricted()
          && hasConfirmedAdult()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500
          && !exists(/databases/$(database)/documents/users/$(get(/databases/$(database)/documents/posts/$(postId)).data.authorId)/blocked/$(request.auth.uid));
        // Text-size cap mirrored from create. Without it, an author could
        // edit a 500-char reply into multi-KB content and bypass both the
        // length cap and (combined with onReplyUpdated re-running moderation
        // in functions/index.js) the original-text moderation pass that ran
        // at create time.
        allow update: if isAuth()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow delete: if isAuth()
          && (resource.data.authorId == request.auth.uid
              || get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid);
      }

      match /likes/{likeUserId} {
        allow read: if isAuth();
        // Same block enforcement as replies — a blocked user shouldn't be
        // able to bump someone's likeCount.
        allow create: if isAuth() && request.auth.uid == likeUserId
          && !exists(/databases/$(database)/documents/users/$(get(/databases/$(database)/documents/posts/$(postId)).data.authorId)/blocked/$(request.auth.uid));
        allow delete: if isAuth()
          && (request.auth.uid == likeUserId
              || get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid);
      }

      match /reflections/{reflectionId} {
        allow read: if isAuth();
        allow create: if isAuth()
          && request.resource.data.authorId == request.auth.uid
          && !exists(/databases/$(database)/documents/users/$(get(/databases/$(database)/documents/posts/$(postId)).data.authorId)/blocked/$(request.auth.uid));
        allow update, delete: if isAuth()
          && resource.data.authorId == request.auth.uid;
      }
    }

    match /conversations/{convoId} {
      allow read: if isAuth()
        && request.auth.uid in resource.data.participants;
      // messageCount is the per-user 5-message rate-limit ledger and feeds
      // the cap check in the messages create rule below. Without locking
      // it, a malicious peer could pre-set messageCount.{victim_uid} = 5
      // on the conversation doc to seal the victim's DM slot before they
      // ever sent a message. On create we require either:
      //   - messageCount absent or empty (the most defensive shape), or
      //   - every value in the map equal to 0 (matches what the iOS clients
      //     currently write: ["uidA": 0, "uidB": 0]).
      // Either way no slot can land >0 at create time.
      //
      // Participants is hard-capped at exactly 2 distinct uids. Without this
      // cap, a tampered client could create a 3+ participant conversation,
      // which would short-circuit the block-enforcement clause in the
      // messages create rule below (the size != 2 leg). OtherProfileView.
      // startConversation is the only legitimate creator and writes exactly
      // [uid, otherUid], so the cap doesn't break any current call site.
      allow create: if isAuth()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants[0] != request.resource.data.participants[1]
        && (
          !request.resource.data.keys().hasAny(['messageCount'])
          || request.resource.data.messageCount.size() == 0
          || request.resource.data.messageCount.values().hasOnly([0])
        );
      // On update messageCount can only change in two ways: not at all, or
      // by exactly +1 to the calling user's own slot. Other participants'
      // slots are immutable from the client side; this preserves the cap
      // (a peer can't reset themselves) and prevents the same pre-seal
      // attack via update. ConversationView.sendMessage's transaction
      // increments messageCount.{auth.uid} by 1 inside the same write that
      // creates the message, which matches this constraint exactly.
      // The legacy onMessageCreatedUpdateCount Cloud Function and the
      // post-moderation decrement in onMessageCreatedModerate use the
      // Admin SDK and bypass these rules.
      allow update: if isAuth()
        && request.auth.uid in resource.data.participants
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['participants', 'createdAt'])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['messageCount'])
          || (
            request.resource.data.messageCount is map
            && request.resource.data.messageCount.diff(resource.data.get('messageCount', {}))
                 .affectedKeys().hasOnly([request.auth.uid])
            && request.resource.data.messageCount.get(request.auth.uid, 0)
                 == resource.data.get('messageCount', {}).get(request.auth.uid, 0) + 1
          )
        );
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convoId)).data.participants;
        // Block enforcement: the sender can't deliver a message to a
        // conversation if any other participant has blocked them. Without
        // this, BlockedUsersCache only hides messages on the blocker's
        // device — the rule didn't actually stop the write. We resolve
        // the "other participant" by scanning the convo doc's participants
        // and asserting no /users/{other}/blocked/{sender} doc exists.
        allow create: if isAuth()
          && notRestricted()
          && hasConfirmedAdult()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          // Schema lockdown: only the four expected fields can land on a
          // message doc. Without this, a malicious or buggy client could
          // write arbitrary extra fields and let a future Cloud Function
          // trust them. The clientCountedV1 marker is required (not just
          // permitted) because every legitimate write from the current
          // client sets it, and the rate-cap guarantee depends on the
          // matching transactional increment in ConversationView.sendMessage.
          && request.resource.data.keys().hasOnly(['senderId', 'text', 'createdAt', 'clientCountedV1'])
          && request.resource.data.keys().hasAll(['senderId', 'text', 'createdAt', 'clientCountedV1'])
          && request.resource.data.clientCountedV1 == true
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convoId)).data.participants
          && get(/databases/$(database)/documents/conversations/$(convoId)).data.get('messageCount', {}).get(request.auth.uid, 0) < 5
          // Two-participant DM enforcement. The conversations create rule
          // above caps participants at exactly 2, so this branch is the
          // only shape that can legitimately exist. Previously this clause
          // short-circuited true for participants.size() != 2 — combined
          // with an unbounded create rule, a tampered client could craft a
          // 3+ participant conversation and bypass the block check. The
          // create-side cap closes the front door for new convos; this
          // strict size==2 assertion closes the back door for any legacy
          // multi-party docs that may still exist.
          && get(/databases/$(database)/documents/conversations/$(convoId)).data.participants.size() == 2
          && !exists(/databases/$(database)/documents/users/$(
            get(/databases/$(database)/documents/conversations/$(convoId)).data.participants[0] == request.auth.uid
              ? get(/databases/$(database)/documents/conversations/$(convoId)).data.participants[1]
              : get(/databases/$(database)/documents/conversations/$(convoId)).data.participants[0]
          )/blocked/$(request.auth.uid));
        allow update, delete: if false;
      }
    }

    match /feelingCircles/{circleId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth();
      // Updates can only touch `participants`, can only add or remove the
      // calling uid, and must keep the list at <= 20. Previously the rule
      // required only that auth.uid was somewhere in the new list — which
      // let a tampered client forcibly add other users (e.g. setting
      // participants to [auth.uid, victim_a, victim_b]) without their
      // consent. The two `difference(...).hasOnly([auth.uid])` clauses
      // structurally lock both directions: nobody else can be added by
      // this user, and nobody else can be evicted by this user. Joining
      // (FeelingCircleView.joinCircle's arrayUnion([uid])) and leaving
      // both fit the new shape so legitimate flows still work.
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['participants'])
        && request.resource.data.participants is list
        && request.resource.data.participants.size() <= 20
        && request.resource.data.participants.toSet()
            .difference(resource.data.participants.toSet())
            .hasOnly([request.auth.uid])
        && resource.data.participants.toSet()
            .difference(request.resource.data.participants.toSet())
            .hasOnly([request.auth.uid]);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/feelingCircles/$(circleId)).data.participants;
        allow create: if isAuth()
          && notRestricted()
          && hasConfirmedAdult()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && request.auth.uid in get(/databases/$(database)/documents/feelingCircles/$(circleId)).data.participants;
        allow update, delete: if false;
      }
    }

    match /dailyMoment/{dateId} {
      allow read: if isAuth();
      allow write: if false;
    }

    match /finalPosts/{postId} {
      allow read: if isAuth();
      allow create: if false;
      allow update, delete: if false;
    }

    // Reports collection — written when a user submits a report via ReportSheet.
    //
    // Hardened against client abuse:
    //   - `reportedBy` must match the authenticated caller — prevents framing
    //     another user by spoofing their uid into the report doc.
    //   - `type` is constrained to the four surfaces the app actually reports
    //     (post/reply/user/conversation) so a malicious client can't dump
    //     arbitrary shapes into the moderation queue.
    //   - `status` is pinned to 'pending' on create so clients can't submit
    //     pre-dismissed reports to sabotage moderation.
    //   - `createdAt` is pinned to server time (`request.time`) so clients
    //     can't backdate or future-date reports.
    //   - `keys().hasOnly(...)` locks the schema — no extra fields slip in.
    //   - `reason.size() <= 50` caps the machine-code length (the free-text
    //     label is separate and also bounded by client UI).
    //   - `text.size() <= 4000` caps the snapshot of the reported content.
    //     The post text-cap is 2000; 4000 is generous for legitimate reports
    //     and tight enough that a tampered client can't push a 200KB blob
    //     into the moderation queue (admin.html renders 50 reports per
    //     page; uncapped text would let a single abuser push megabytes per
    //     page render through rateLimitReports's 20/hour ceiling).
    //
    // Reads and mutations are denied to all clients — only the Admin SDK
    // (moderator tooling / Cloud Functions) should touch the queue after
    // creation. Rate-limiting spam reports is deferred to a Cloud Function
    // since Firestore rules can't count aggregate writes.
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth()
        && request.resource.data.reportedBy == request.auth.uid
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 50
        && request.resource.data.type in ['post', 'reply', 'user', 'conversation']
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time
        && (!('text' in request.resource.data.keys())
            || (request.resource.data.text is string
                && request.resource.data.text.size() <= 4000))
        && request.resource.data.keys().hasOnly([
             'reportedBy', 'reason', 'reasonLabel', 'type', 'status', 'createdAt',
             'postId', 'replyId', 'conversationId',
             'reportedUserId', 'reportedHandle', 'text'
           ]);
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'reviewedBy', 'reviewedAt', 'action']);
      allow delete: if false;
    }

    match /admins/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Server-only audit log of admin actions. Cloud Functions write here
    // via Admin SDK (which bypasses these rules); admins can read for
    // accountability; nobody else has any access. See
    // functions/index.js: auditUserRestriction / auditReportResolution.
    match /adminAuditLog/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /pendingDeletions/{uid} {
      allow read: if false;
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['cancelled', 'cancelledAt']);
      // Owners can delete their own pendingDeletion. Without this, a user
      // whose previous deletion was cancelled (doc exists with cancelled=true)
      // could never start a new deletion: create fails because the doc exists,
      // update is restricted to just cancelled/cancelledAt, and previously
      // delete was forbidden entirely. Clients now delete any stale doc before
      // creating a fresh one — see SettingsView.deleteAccount. Deleting a
      // non-cancelled pending doc effectively "cancels" it (the grace-window
      // re-read in onPendingDeletionCreated sees the missing doc and bails),
      // which is the same user-facing outcome as the existing cancelled flag.
      allow delete: if isOwner(uid);
    }

    match /{path=**}/replies/{replyId} {
      allow read: if isAuth();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
